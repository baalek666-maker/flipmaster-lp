---
interface Props {
  src: string;        // e.g. "/images/card1.jpg"
  alt: string;
  class?: string;
  loading?: 'lazy' | 'eager';
  decoding?: 'async' | 'auto' | 'sync';
  width?: number;
  height?: number;
}

const { src, alt, class: className, loading = 'lazy', decoding = 'async', width, height } = Astro.props;

// Derive WebP path: /images/foo.jpg → /images/webp/foo.webp
const webpSrc = src.replace('/images/', '/images/webp/').replace(/\.(jpg|jpeg|png)$/i, '.webp');
---

<picture>
  <source srcset={webpSrc} type="image/webp" />
  <img
    src={src}
    alt={alt}
    class={className}
    loading={loading}
    decoding={decoding}
    {width}
    {height}
  />
</picture>