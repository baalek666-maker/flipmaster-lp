<script>
  const video = document.getElementById('vsl-video');
  const playBtn = document.getElementById('vsl-play-btn');

  if (video && playBtn) {
    playBtn.addEventListener('click', () => {
      video.muted = false;
      video.play();
      playBtn.style.opacity = '0';
      playBtn.style.pointerEvents = 'none';
    });

    video.addEventListener('ended', () => {
      playBtn.style.opacity = '1';
      playBtn.style.pointerEvents = 'auto';
    });
  }

  // Tracking: ViewContent on homepage (via Layout window.trackEvent)
  if (typeof (window as any).trackEvent === 'function') {
    (window as any).trackEvent('view_content', { content_name: 'homepage', content_category: 'landing_page' });
  }
</script>

