---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Désinscription — Pokévendre Pro">
  <section class="unsub-container">
    <div class="unsub-card" id="unsubCard">
      <div class="icon-wrap">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
          <polyline points="22 4 12 14.01 9 11.01"/>
        </svg>
      </div>
      <h1>Désinscription confirmée</h1>
      <p>Tu ne recevras plus d'emails de notre part.</p>
      <p class="sub">Si tu changes d'avis, tu peux toujours repasser le quiz pour recevoir à nouveau nos conseils.</p>
      <a href="https://pokevendrepro.com" class="back-link">← Retour au site</a>
    </div>

    <div class="unsub-card error-card" id="errorCard" style="display:none">
      <div class="icon-wrap error">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="10"/>
          <line x1="15" y1="9" x2="9" y2="15"/>
          <line x1="9" y1="9" x2="15" y2="15"/>
        </svg>
      </div>
      <h1>Erreur</h1>
      <p id="errorMsg">Un problème est survenu. Réessaie ou contacte-nous directement.</p>
      <a href="https://pokevendrepro.com" class="back-link">← Retour au site</a>
    </div>

    <div class="loading" id="loading">
      <div class="spinner"></div>
      <p>Traitement en cours…</p>
    </div>
  </section>
</Layout>

<style>
  .unsub-container {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #0f0f1a;
    padding: 2rem;
  }

  .unsub-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 3rem 2.5rem;
    max-width: 480px;
    width: 100%;
    text-align: center;
  }

  .icon-wrap {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: rgba(74, 222, 128, 0.1);
    color: #4ade80;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
  }

  .icon-wrap.error {
    background: rgba(248, 113, 113, 0.1);
    color: #f87171;
  }

  h1 {
    color: #e2e8f0;
    font-size: 1.5rem;
    margin: 0 0 1rem;
  }

  p {
    color: #9ca3af;
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0 0 0.75rem;
  }

  .sub {
    color: #6b7280;
    font-size: 0.85rem;
  }

  .back-link {
    display: inline-block;
    margin-top: 1.5rem;
    color: #a855f7;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s;
  }

  .back-link:hover {
    color: #c084fc;
  }

  .error-card {
    border-color: rgba(248, 113, 113, 0.2);
  }

  .loading {
    text-align: center;
    color: #9ca3af;
  }

  .spinner {
    width: 40px;
    height: 40px;
    border: 3px solid rgba(168, 85, 247, 0.2);
    border-top-color: #a855f7;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
    margin: 0 auto 1rem;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }
</style>

<script>
  const params = new URLSearchParams(window.location.search);
  const email = params.get('email');

  const unsubCard = document.getElementById('unsubCard');
  const errorCard = document.getElementById('errorCard');
  const loading = document.getElementById('loading');
  const errorMsg = document.getElementById('errorMsg');

  if (!email) {
    loading.style.display = 'none';
    errorCard.style.display = 'block';
    errorMsg.textContent = 'Aucun email fourni. Clique sur le lien de désinscription dans l\'email.';
  } else {
    fetch(`https://api.pokevendrepro.com/unsubscribe?email=${encodeURIComponent(email)}`)
      .then(r => r.json())
      .then(data => {
        loading.style.display = 'none';
        if (data.status === 'ok') {
          unsubCard.style.display = 'block';
        } else {
          errorCard.style.display = 'block';
          errorMsg.textContent = data.message || 'Erreur inconnue';
        }
      })
      .catch(err => {
        loading.style.display = 'none';
        errorCard.style.display = 'block';
        errorMsg.textContent = 'Erreur de connexion. Réessaie plus tard.';
      });
  }
</script>