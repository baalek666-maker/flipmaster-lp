const params = new URLSearchParams(window.location.search);
const profilKey = (params.get('profil') || 'debutant').toLowerCase();
const prenom = params.get('prenom') || 'revendeur';
const leadEmail = params.get('email') || '';
const profile = profiles[profilKey] || profiles.debutant;

function applyProfile() {
  document.getElementById('prenom-display').textContent = prenom;
  document.getElementById('profil-name-display').textContent = profile.name;
  document.getElementById('profile-emoji').textContent = profile.emoji;
  document.getElementById('profile-title').textContent = profile.name;
  document.getElementById('profile-tagline').textContent = profile.tagline;
  document.getElementById('profile-tagline').style.color = profile.color;
  document.getElementById('profile-advice').textContent = profile.advice;
  document.getElementById('level-label').textContent = profile.levelLabel;
  document.getElementById('level-label').style.color = profile.color;

  var traitsEl = document.getElementById('profile-traits');
  profile.traits.forEach(function(t) {
    var div = document.createElement('div');
    div.className = 'profile-trait-item';
    div.innerHTML = '<span class="profile-trait-dot" style="background:' + profile.color + '"></span><span>' + t + '</span>';
    traitsEl.appendChild(div);
  });

  var strengthsEl = document.getElementById('profile-strengths');
  profile.strengths.forEach(function(s) {
    var div = document.createElement('div');
    div.className = 'strength-item';
    div.textContent = '\u2713 ' + s;
    strengthsEl.appendChild(div);
  });

  var weaknessesEl = document.getElementById('profile-weaknesses');
  profile.weaknesses.forEach(function(w) {
    var div = document.createElement('div');
    div.className = 'weakness-item';
    div.textContent = '\u2022 ' + w;
    weaknessesEl.appendChild(div);
  });

  document.getElementById('profile-card').classList.remove('hidden');

  applyGlow();
  animateLevelBar();
  launchConfetti();
  setTimeout(launchProfileParticles, 600);
}

function applyGlow() {
  var c = profile.color;
  var rgb = profile.colorRgb;

  document.getElementById('bg-glow-1').style.background = 'radial-gradient(circle, rgba(' + rgb + ',0.15) 0%, transparent 70%)';
  document.getElementById('bg-glow-2').style.background = 'radial-gradient(circle, rgba(' + rgb + ',0.08) 0%, transparent 70%)';

  var card = document.getElementById('profile-card-inner');
  card.style.borderColor = 'rgba(' + rgb + ',0.3)';
  card.style.boxShadow = '0 0 30px rgba(' + rgb + ',0.1), 0 0 60px rgba(' + rgb + ',0.05)';

  var checkCircle = document.getElementById('check-circle');
  checkCircle.style.background = 'linear-gradient(135deg, rgba(' + rgb + ',0.2), rgba(' + rgb + ',0.05))';
  checkCircle.style.borderColor = 'rgba(' + rgb + ',0.4)';

  var adviceBox = document.getElementById('advice-box');
  adviceBox.style.background = 'rgba(' + rgb + ',0.08)';
  adviceBox.style.borderColor = 'rgba(' + rgb + ',0.2)';

  var step1Card = document.getElementById('step1-card');
  if (step1Card) {
    step1Card.style.borderColor = 'rgba(' + rgb + ',0.2)';
  }
  var step1Icon = document.getElementById('step1-icon');
  if (step1Icon) {
    step1Icon.style.background = 'rgba(' + rgb + ',0.2)';
    step1Icon.style.color = c;
  }
}

function animateLevelBar() {
  var bar = document.getElementById('level-bar');
  bar.style.background = 'linear-gradient(90deg, ' + profile.color + ', rgba(' + profile.colorRgb + ',0.6))';
  setTimeout(function() { bar.style.width = profile.level + '%'; }, 400);
}
// ===== 5. CONFETTI =====
function launchConfetti() {
  var canvas = document.getElementById('confetti-canvas');
  var ctx = canvas.getContext('2d');
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;

  var colors = [profile.color, '#ffffff', '#a78bfa', '#facc15', '#f87171', '#4ade80'];
  var particles = [];

  for (var i = 0; i < 150; i++) {
    particles.push({
      x: Math.random() * canvas.width,
      y: Math.random() * canvas.height - canvas.height,
      w: Math.random() * 8 + 4,
      h: Math.random() * 4 + 2,
      color: colors[Math.floor(Math.random() * colors.length)],
      vx: (Math.random() - 0.5) * 3,
      vy: Math.random() * 3 + 2,
      rotation: Math.random() * 360,
      rotationSpeed: (Math.random() - 0.5) * 10,
      opacity: 1
    });
  }

  var startTime = Date.now();
  var duration = 4000;

  function animate() {
    var elapsed = Date.now() - startTime;
    if (elapsed > duration) {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      return;
    }
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    var fadeFactor = elapsed > duration * 0.7 ? 1 - ((elapsed - duration * 0.7) / (duration * 0.3)) : 1;

    particles.forEach(function(p) {
      p.x += p.vx;
      p.y += p.vy;
      p.vy += 0.05;
      p.rotation += p.rotationSpeed;

      ctx.save();
      ctx.translate(p.x, p.y);
      ctx.rotate(p.rotation * Math.PI / 180);
      ctx.globalAlpha = p.opacity * Math.max(0, fadeFactor);
      ctx.fillStyle = p.color;
      ctx.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);
      ctx.restore();
    });

    requestAnimationFrame(animate);
  }
  animate();

  window.addEventListener('resize', function() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  });
}

// ===== 3. PROFILE PARTICLES =====
function launchProfileParticles() {
  var canvas = document.getElementById('profile-particles-canvas');
  var ctx = canvas.getContext('2d');
  canvas.width = window.innerWidth;
  canvas.height = window.innerHeight;

  var particles = [];
  var maxParticles = 40;

  function createParticle() {
    return {
      x: Math.random() * canvas.width,
      y: -10,
      size: Math.random() * 3 + 1,
      speedY: Math.random() * 0.8 + 0.3,
      speedX: (Math.random() - 0.5) * 0.5,
      opacity: Math.random() * 0.5 + 0.2,
      color: profile.color
    };
  }

  for (var i = 0; i < maxParticles; i++) {
    var p = createParticle();
    p.y = Math.random() * canvas.height;
    particles.push(p);
  }

  function animate() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    particles.forEach(function(p, idx) {
      p.y += p.speedY;
      p.x += p.speedX;

      if (p.y > canvas.height + 10) {
        particles[idx] = createParticle();
        return;
      }

      ctx.beginPath();
      ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
      ctx.fillStyle = p.color;
      ctx.globalAlpha = p.opacity;
      ctx.fill();
    });
    ctx.globalAlpha = 1;

    requestAnimationFrame(animate);
  }
  animate();

  window.addEventListener('resize', function() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  });
}

// ===== 4. SHARE / COPY LINK =====
function copyShareLink() {
  var input = document.getElementById('share-url');
  var url = input.value;
  if (navigator.clipboard) {
    navigator.clipboard.writeText(url).then(function() {
      showCopyFeedback();
    });
  } else {
    input.select();
    document.execCommand('copy');
    showCopyFeedback();
  }
}

function showCopyFeedback() {
  var fb = document.getElementById('copy-feedback');
  fb.style.opacity = '1';
  document.getElementById('copy-btn-text').textContent = 'Copié !';
  setTimeout(function() {
    fb.style.opacity = '0';
    document.getElementById('copy-btn-text').textContent = 'Copier';
  }, 2000);
}

// ===== 5. STRIPE CHECKOUT =====
// ===== META PIXEL TRACKING =====
// Lead + Advanced Matching with email from quiz optin
// Helper: send event to CAPI (server-side) for deduplication
function sendCapiEvent(eventName, eventData, eventId) {
  var payload = { event_name: eventName, event_data: eventData, event_id: eventId };
  if (leadEmail) { payload.user_data = { em: leadEmail }; }
  // Attach _fbc/_fbp cookies for server-side attribution
  var mc = (typeof window.getMetaCookies === 'function') ? window.getMetaCookies() : {};
  if (mc.fbc) { payload.user_data = payload.user_data || {}; payload.user_data.fbc = mc.fbc; }
  if (mc.fbp) { payload.user_data = payload.user_data || {}; payload.user_data.fbp = mc.fbp; }
  fetch('/api/capi', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload)
  }).catch(function() {}); // fire-and-forget
}

if (typeof fbq !== 'undefined') {
  var leadEventId = 'lead_' + profilKey + '_' + Date.now();
  if (leadEmail) {
    // SHA-256 hash email for Advanced Matching
    crypto.subtle.digest('SHA-256', new TextEncoder().encode(leadEmail.trim().toLowerCase())).then(function(buf) {
      var hash = Array.from(new Uint8Array(buf)).map(function(b) { return b.toString(16).padStart(2, '0'); }).join('');
      fbq('init', '947903204620148', { em: hash });
      fbq('track', 'Lead', {
        content_name: 'quiz_lead',
        content_category: 'quiz',
        value: 0,
        currency: 'EUR'
      }, { eventID: leadEventId });
    });
  } else {
    fbq('track', 'Lead', {
      content_name: 'quiz_lead',
      content_category: 'quiz',
      value: 0,
      currency: 'EUR'
    }, { eventID: leadEventId });
  }
  // CAPI server-side Lead (same eventID for dedup)
  sendCapiEvent('Lead', {
    content_name: 'quiz_lead',
    content_category: 'quiz',
    value: 0,
    currency: 'EUR'
  }, leadEventId);
}

function reservePlace() {
  var btn = document.getElementById('reserve-btn');
  var btnText = document.getElementById('reserve-btn-text');
  btn.disabled = true;
  btnText.textContent = 'Réservation...';

  // Meta Pixel: AddToWishlist (reservation = intent signal)
  if (typeof fbq !== 'undefined') {
    var reserveEventId = 'reserve_' + profilKey + '_' + Date.now();
    fbq('track', 'AddToWishlist', {
      content_name: 'pokevendre_pro_reserve',
      content_category: 'digital_course'
    }, { eventID: reserveEventId });
    sendCapiEvent('AddToWishlist', {
      content_name: 'pokevendre_pro_reserve',
      content_category: 'digital_course'
    }, reserveEventId);
  }

  // Call VPS API to save reservation, then redirect to confirmation page
  fetch('/api/reserve', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ email: leadEmail, prenom: prenom, profil: profilKey })
  })
  .then(function(res) { return res.json(); })
  .then(function(data) {
    window.location.href = '/reserve?prenom=' + encodeURIComponent(prenom) + '&profil=' + encodeURIComponent(profilKey);
  })
  .catch(function(err) {
    console.error('Reserve error:', err);
    // Fallback: still redirect to confirmation page even if API fails
    window.location.href = '/reserve?prenom=' + encodeURIComponent(prenom) + '&profil=' + encodeURIComponent(profilKey);
  });
}

// ===== INIT =====
document.addEventListener('DOMContentLoaded', function() {
  applyProfile();
  document.getElementById('share-url').value = window.location.origin + '/quiz?ref=' + profilKey;
});
</script>
</Layout>
